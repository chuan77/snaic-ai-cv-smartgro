# FastAPI backend configuration. Copy this file to `.env` and adjust values as needed.

# Host the uvicorn server binds to.
SMARTCART_HOST=0.0.0.0
# Port the uvicorn server listens on.
SMARTCART_PORT=8000
# Enable uvicorn's auto-reload (dev only; set to false in production).
SMARTCART_RELOAD=true
# Comma-separated list of origins allowed to call this API (CORS). Must match the frontend's dev server URL (see frontend/.env.example's VITE_DEV_SERVER_PORT).
SMARTCART_CORS_ORIGINS=http://localhost:5173
# Path to the trained YOLO weights file used for detection.
SMARTCART_WEIGHTS_PATH=./runs/detect/train/weights/best.pt
# Path to the catalog CSV (class_id,product_name,price_usd) served by GET /catalog.
SMARTCART_CATALOG_PATH=./artifacts/catalog_prices.csv

# --- Active Learning / Label Studio integration ---
# Base URL of the Label Studio instance (used to resolve task image URLs and for pushing tasks).
LABEL_STUDIO_URL=http://localhost:8080
# Label Studio API token (Account & Settings -> Access Token). Required to fetch LS-hosted images and to push tasks.
LABEL_STUDIO_API_KEY=
# RectangleLabels control name in the LS labeling config (from_name); must match the <RectangleLabels name=...>.
SMARTCART_LS_FROM_NAME=label
# Image object name in the LS labeling config (to_name); must match the <Image name=...>.
SMARTCART_LS_TO_NAME=image
# Task data field holding the image URL (matches $image in the labeling config).
SMARTCART_LS_DATA_KEY=image
# Model version string reported to Label Studio for pre-annotations.
SMARTCART_MODEL_VERSION=smartcart-yolo11n-v1
# Label Studio project id that captured frames are pushed into (used by push_captures_to_label_studio.py).
SMARTCART_LS_PROJECT_ID=
# Directory where uncertain production frames are staged for review.
SMARTCART_CAPTURE_DIR=./artifacts/active_learning_staging
# Confidence threshold below which a detection makes a frame "uncertain" and eligible for capture.
SMARTCART_CAPTURE_CONF_THRESHOLD=0.5
# Enable/disable uncertainty capture on the live /predict path.
SMARTCART_CAPTURE_ENABLED=true
# Public base URL where staged images are served (mounted at /staging) so Label Studio can display them.
SMARTCART_STAGING_PUBLIC_URL=http://localhost:8000/staging
# Minimum detection count a staged capture must have to be pushed by push_captures_to_label_studio.py
# (0 = push everything, including zero-detection frames; 1 = only frames the detector saw something in).
SMARTCART_PUSH_MIN_DETECTIONS=0
# Minimum mAP50 a retrained candidate must reach for retrain_from_label_studio.py's audit gate to report PASSED.
SMARTCART_RETRAIN_MIN_MAP50=0.5
